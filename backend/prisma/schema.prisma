generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  NEW
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Order {
  id           Int         @id @default(autoincrement())
  name         String
  phone        String
  services     String[]
  comment      String?
  adminComment String?
  status       OrderStatus @default(NEW)
  price        Int         @default(0)
  scheduledAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}
