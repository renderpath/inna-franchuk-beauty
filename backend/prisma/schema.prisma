generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  NEW
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Service {
  id        Int      @id @default(autoincrement())
  title     String
  price     Int
  duration  Int      @default(120)
  createdAt DateTime @default(now())
}

model Order {
  id         Int      @id @default(autoincrement())
  name       String
  phone      String
  services   String
  totalPrice Int
  date       String
  time       String
  status     String   @default("new")
  createdAt  DateTime @default(now())
}
